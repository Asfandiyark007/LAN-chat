    {
      "id": "tnXIkXY-v1MtMlp22veb9",
      "type": "text",
      "x": 1220.21875,
      "y": 1407.0065104166665,
      "width": 580.1903076171875,
      "height": 385,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b1G",
      "roundness": null,
      "seed": 1959218369,
      "version": 691,
      "versionNonce": 573327745,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781073785019,
      "link": null,
      "locked": false,
      "text": "1) When user first time tries to connect \n    to the server it sends the registration\n     message (username) \n2) We will just keep only user name for\n    now and another group will be made \n    that keeps the registered users record\n    for the session. \n3) When username  is accepted , the new \n    welcome message is sent and everyone\n    in the registered list can see username\n    and messages.  ",
      "fontSize": 28,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1) When user first time tries to connect \n    to the server it sends the registration\n     message (username) \n2) We will just keep only user name for\n    now and another group will be made \n    that keeps the registered users record\n    for the session. \n3) When username  is accepted , the new \n    welcome message is sent and everyone\n    in the registered list can see username\n    and messages.  ",
      "autoResize": true,
      "lineHeight": 1.25
    },
