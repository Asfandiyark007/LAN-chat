    {
      "id": "eZ2995JmK7fw5k-RKxdJz",
      "type": "text",
      "x": 939.36328125,
      "y": 693.8984375,
      "width": 565.939453125,
      "height": 325,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "mc3kbjlMxA8_yg7wMSL0W"
      ],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 1734504498,
      "version": 948,
      "versionNonce": 379366450,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779085936885,
      "link": null,
      "locked": false,
      "text": "Server:\n1) When it receives a message from user, it sends the \n   acknowledgement to the user and we use that to \n   control the terminal color (green or red).\n2) When a user sends message to the server, the server\n    should send the same message to everyone connected\n    to that server with the sender username. (not the \n     sender)\n3) when a user disconnect the server should remove him\n   from the connected clients.\n4) When a user connects they should get the most recent\n    messages of previous chat (like 5 most recent).\n5) Server keeps the Logs of users messages.   ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Server:\n1) When it receives a message from user, it sends the \n   acknowledgement to the user and we use that to \n   control the terminal color (green or red).\n2) When a user sends message to the server, the server\n    should send the same message to everyone connected\n    to that server with the sender username. (not the \n     sender)\n3) when a user disconnect the server should remove him\n   from the connected clients.\n4) When a user connects they should get the most recent\n    messages of previous chat (like 5 most recent).\n5) Server keeps the Logs of users messages.   ",
      "autoResize": true,
      "lineHeight": 1.25
    },
